# ==============================================================================
# DEDEMIT UMKM: AI BUSINESS OS FOR ALL INDONESIAN MSMEs
# ROOT ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================

# --- Global Environment Configuration ---
ENV=development # development | staging | production
PROJECT_NAME="Dedemit UMKM AI Business OS"

# --- Database Configurations (PostgreSQL) ---
# Used by FastAPI Backend and Docker Compose
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secretpassword
DB_NAME=dedemit_db
DATABASE_URL=postgresql://postgres:secretpassword@localhost:5432/dedemit_db
REDIS_URL=redis://localhost:6379/0

# --- Security / Authentication ---
# JWT Secret for password hashing and authentication sessions
JWT_SECRET=super_secret_jwt_key_please_change_in_production_1234567890
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 Hours

# --- AI Integrations ---
# Google Gemini API Key (Highly Recommended for Free AI tier)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Payment Gateway (Midtrans Snap) ---
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
MIDTRANS_IS_PRODUCTION=false # false for Sandbox, true for Production

# --- Storage Configuration (Supabase/S3 Storage for product photos/receipts) ---
STORAGE_BUCKET_URL=your_supabase_storage_bucket_url_here

# --- Telegram Bot Configurations ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=dedemit_assistant_bot
OWNER_CHAT_ID=your_telegram_owner_chat_id_here

# --- Backend API Connection for Clients (Web & Mobile) ---
BACKEND_PORT=8000
BACKEND_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000 # Next.js accessible API URL
